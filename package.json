{
  "name": "astrosite",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "bld": "astro build",
    "check": "bun run --parallel typecheck lint test",
    "check:full": "bun run --parallel --no-exit-on-error typecheck lint test",
    "dev": "astro dev",
    "lint": "bun run --parallel lint:src lint:tooling",
    "lint:src": "oxlint src/",
    "lint:tooling": "oxlint astro.config.ts e2e/ scripts/",
    "test": "bun test src/ scripts/",
    "test:coverage": "bun test src/ scripts/ --coverage",
    "test:e2e": "bun test e2e/",
    "test:slow": "vitest run src/ scripts/",
    "typecheck": "bun run --parallel typecheck:astro typecheck:tooling",
    "typecheck:astro": "astro check --tsconfig src/tsconfig.json",
    "typecheck:tooling": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "rehype-external-links": "^3.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "11.0.5"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/ts-plugin": "^1.10.7",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@types/bun": "^1.3.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "astro": "^6.1.5",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "oxlint-tsgolint": "^0.20.0",
    "postcss": "^8.5.9",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4",
    "wrangler": "^4.81.1"
  }
}
