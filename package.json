{
  "name": "astrosite",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "bld": "astro build",
    "check": "bun run --parallel typecheck lint test",
    "check:full": "bun run --parallel --no-exit-on-error typecheck lint test",
    "dev": "astro dev",
    "dpl": "bun check && rm -rf dist/ && astro build && wrangler pages deploy dist/",
    "lint": "oxlint",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "test:slow": "vitest run src/",
    "typecheck": "astro check"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "rehype-external-links": "^3.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "11.0.5"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/ts-plugin": "^1.10.7",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.2",
    "astro": "^6.1.4",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "oxlint-tsgolint": "^0.20.0",
    "postcss": "^8.5.9",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3",
    "wrangler": "^4.81.0"
  }
}
