---
import { getCollection } from "astro:content"

const arr0 = await getCollection("articles")
const arr = arr0.filter(x => x.data.published_at)
---

{
  arr.length ? (
    <>
      <h2>Writing</h2>
        <ul>
        {arr.map(p => (
          <li>
            <a href={`/article/${p.id}`}>{p.data.title}</a>
          </li>
        ))}
      </ul>
    </>
  ) : null
}
