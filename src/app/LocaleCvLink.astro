---
import { getRelativeLocaleUrl } from "astro:i18n"
import { normalizeLocaleHref, type Locale } from "./i18n"

interface Props {
  currentLocale: Locale
  label: string
}

const { currentLocale, label } = Astro.props
const href = normalizeLocaleHref(getRelativeLocaleUrl(currentLocale, "cv"))
---

<a
  href={href}
  class="text-sm font-medium text-slate-700 no-underline hover:text-slate-900"
>
  {label}
</a>
