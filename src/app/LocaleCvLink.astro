---
import { getRelativeLocaleUrl } from "astro:i18n"
import { normalizeLocaleHref, type Locale } from "./i18n"
import SiteNavTextLink from "./SiteNavTextLink.astro"

interface Props {
  currentLocale: Locale
  label: string
}

const { currentLocale, label } = Astro.props
const href = normalizeLocaleHref(getRelativeLocaleUrl(currentLocale, "cv"))
---

<SiteNavTextLink href={href}>{label}</SiteNavTextLink>
