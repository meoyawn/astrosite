---
import { getRelativeLocaleUrl } from "astro:i18n"
import { defaultLocale, locales, normalizeLocaleHref, type Locale } from "./i18n"

interface Props {
  currentLocale: Locale
  label: string
  path?: string | undefined
}

const { currentLocale, label, path } = Astro.props
const usesDefaultLocalePrefix =
  Astro.url.pathname === `/${defaultLocale}` ||
  Astro.url.pathname.startsWith(`/${defaultLocale}/`)

const localeLabel: Record<Locale, string> = {
  en: "EN",
  ru: "RU",
  tt: "TT",
}

const unprefixDefaultLocaleHref = (href: string): string =>
  href === `/${defaultLocale}`
    ? "/"
    : href.startsWith(`/${defaultLocale}/`)
      ? href.slice(defaultLocale.length + 1)
      : href

function hrefFor(locale: Locale): string {
  const href = normalizeLocaleHref(
    path ? getRelativeLocaleUrl(locale, path) : getRelativeLocaleUrl(locale),
  )

  if (!usesDefaultLocalePrefix && locale === defaultLocale) {
    return unprefixDefaultLocaleHref(href)
  }

  return href
}
---

<nav aria-label={label} class="m-0">
  <ul class="m-0 flex list-none gap-1 p-0 text-sm font-medium">
    {
      locales.map(locale => {
        const href = hrefFor(locale)

        return (
          <li>
            <a
              href={href}
              aria-current={locale === currentLocale ? "page" : undefined}
              class:list={[
                "rounded border px-3 py-1 no-underline transition-colors",
                locale === currentLocale
                  ? "border-slate-900 bg-slate-900 text-white"
                  : "border-slate-300 text-slate-700 hover:border-slate-900 hover:text-slate-900",
              ]}
            >
              {localeLabel[locale]}
            </a>
          </li>
        )
      })
    }
  </ul>
</nav>
