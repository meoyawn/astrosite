---
import { getRelativeLocaleUrl } from "astro:i18n"
import { defaultLocale, normalizeLocaleHref, type Locale } from "./i18n"
import LocaleSwitcher from "./LocaleSwitcher.astro"

type SiteNavPath = "home" | "consulting" | "cv"

interface Props {
  class?: string | undefined
  currentLocale: Locale
  currentPath?: SiteNavPath | undefined
}

interface SiteNavCopy {
  consulting: string
  cv: string
  home: string
  navLabel: string
  switcherLabel: string
}

const copyByLocale: Record<Locale, SiteNavCopy> = {
  en: {
    consulting: "Consulting",
    cv: "CV",
    home: "Home",
    navLabel: "Site navigation",
    switcherLabel: "Switch language",
  },
  ru: {
    consulting: "Консалтинг",
    cv: "Резюме",
    home: "Главная",
    navLabel: "Навигация по сайту",
    switcherLabel: "Сменить язык",
  },
  tt: {
    consulting: "Консалтинг",
    cv: "Резюме",
    home: "Баш бит",
    navLabel: "Сайт навигациясе",
    switcherLabel: "Башка телләр",
  },
}

const { currentLocale, currentPath, class: className } = Astro.props
const copy = copyByLocale[currentLocale]
const switcherPath = currentPath === "home" ? undefined : currentPath
const shouldShowLocaleSwitcher = currentPath !== undefined
const usesDefaultLocalePrefix =
  Astro.url.pathname === `/${defaultLocale}` ||
  Astro.url.pathname.startsWith(`/${defaultLocale}/`)
const unprefixDefaultLocaleHref = (href: string): string =>
  href === `/${defaultLocale}`
    ? "/"
    : href.startsWith(`/${defaultLocale}/`)
      ? href.slice(defaultLocale.length + 1)
      : href
const rawHrefFor = (locale: Locale, path: SiteNavPath): string =>
  normalizeLocaleHref(
    path === "home"
      ? getRelativeLocaleUrl(locale)
      : getRelativeLocaleUrl(locale, path),
  )

function hrefFor(locale: Locale, path: SiteNavPath): string {
  const href = rawHrefFor(locale, path)

  if (!usesDefaultLocalePrefix && locale === defaultLocale) {
    return unprefixDefaultLocaleHref(href)
  }

  return href
}

const links: { label: string; path: SiteNavPath }[] = [
  { label: copy.home, path: "home" },
  { label: copy.consulting, path: "consulting" },
  { label: copy.cv, path: "cv" },
]
---

<nav
  aria-label={copy.navLabel}
  class:list={[
    "mb-6 flex flex-row flex-wrap items-center justify-between gap-3",
    className,
  ]}
>
  <ul class="m-0 flex list-none flex-row flex-wrap gap-x-4 gap-y-2 p-0">
    {
      links.map(link => {
        const isCurrent = currentPath === link.path

        return (
          <li class="m-0 p-0">
            <a
              href={hrefFor(currentLocale, link.path)}
              aria-current={isCurrent ? "page" : undefined}
              class:list={[
                "text-base font-medium text-zinc-950",
                isCurrent
                  ? "font-semibold underline decoration-2 decoration-zinc-950 underline-offset-[3px]"
                  : "hover-underline",
              ]}
            >
              {link.label}
            </a>
          </li>
        )
      })
    }
  </ul>
  {
    shouldShowLocaleSwitcher ? (
      <LocaleSwitcher
        currentLocale={currentLocale}
        path={switcherPath}
        label={copy.switcherLabel}
      />
    ) : null
  }
</nav>
