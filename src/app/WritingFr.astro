---
import { getCollection } from "astro:content"
import { defaultLocale, locales, type Locale } from "./i18n"

interface Props {
  title?: string | undefined
}

const { title = "Writing" } = Astro.props
const arr0 = await getCollection("writing")
type WritingEntry = (typeof arr0)[number]
type PublishedWritingEntry = WritingEntry & {
  data: WritingEntry["data"] & { published_at: Date }
}
const isPublished = (entry: WritingEntry): entry is PublishedWritingEntry =>
  Boolean(entry.data.published_at)
const pathLocale = Astro.url.pathname.split("/")[1]
const locale: Locale =
  locales.find(currentLocale => currentLocale === pathLocale) ?? defaultLocale
const dateFormatter = new Intl.DateTimeFormat(locale, {
  day: "numeric",
  month: "short",
  timeZone: "UTC",
  year: "numeric",
})
const formatDate = (date: Date): string => dateFormatter.format(date)
const dateTime = (date: Date): string => date.toISOString().slice(0, 10)
const arr = arr0
  .filter(isPublished)
  .sort((a, b) => b.data.published_at.getTime() - a.data.published_at.getTime())
---

{
  arr.length ? (
    <section aria-labelledby="writing-heading" class="not-prose mt-12">
      <h2
        id="writing-heading"
        class="mb-4 text-2xl leading-none font-bold text-slate-900"
      >
        {title}
      </h2>
      <ol class="m-0 divide-y divide-zinc-200 border-y border-zinc-200 p-0">
        {arr.map(p => (
          <li class="list-none py-4">
            <time
              datetime={dateTime(p.data.published_at)}
              class="mb-1 block text-sm leading-6 font-medium text-zinc-500 tabular-nums"
            >
              {formatDate(p.data.published_at)}
            </time>
            <article class="min-w-0">
              <a
                href={`/writing/${p.id}/`}
                class="text-lg leading-6 font-semibold text-slate-900 hover-underline"
              >
                {p.data.title}
              </a>
              <p class="mt-1 max-w-[44ch] text-base leading-7 text-zinc-600">
                {p.data.teaser}
              </p>
            </article>
          </li>
        ))}
      </ol>
    </section>
  ) : null
}
