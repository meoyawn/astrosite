---
import { md2html } from "../markdown"
import type { Locale } from "../i18n"
import SiteShell from "../../layouts/SiteShell.astro"
import { fmtDate, fmtExpTime } from "./cv"
import type { CV } from "./data/cv.types"
import type { CVPageCopy } from "./cvPageCopy"
import emailIcon from "./icon/email.svg"
import githubIcon from "./icon/github.svg"
import linkIcon from "./icon/link.svg"
import linkedinIcon from "./icon/linkedin.svg"
import IconLink from "./IconLink.astro"
import Org from "./Org.astro"
import Products from "./Products.astro"

interface Props {
  copy: CVPageCopy
  cv: CV
  locale: Locale
}

const { copy, cv, locale } = Astro.props

const orgHeaderClass = "not-prose mb-2 print:mb-1.5"
const orgTitleClass =
  "m-0 text-lg font-bold leading-tight text-zinc-950 print:text-[13.5px]"
const orgMetaClass =
  "m-0 mt-0.5 text-base leading-snug text-zinc-950 print:text-[12.5px]"
const orgMutedClass = "m-0 text-base leading-snug text-date print:text-[12.5px]"
const orgLinkClass = "text-(--tw-prose-links) hover-underline"
const orgMetaLinkClass = `${orgLinkClass} font-medium`
---

<SiteShell
  title={copy.cvTitle}
  lang={locale}
  currentPath="cv"
  navClass="print:hidden"
  class:list={[
    "mx-0 prose max-w-none",
    "px-0 pb-6",
    "prose-sky",
    "sm:mx-12 sm:pb-12 md:mx-16 md:pb-16",
    "print:m-0 print:text-[12.5px] print:leading-[1.45]",
    "prose-p:my-2 prose-p:print:my-2.5",
    "prose-ul:my-1 prose-ul:print:my-1",
  ]}
>
  <section>
    <h1>{cv.head.name}</h1>
    <h3>{cv.head.title}</h3>

    <p class="grid grid-cols-1 gap-x-8 gap-y-1.5 sm:grid-cols-2 print:grid-cols-2 print:gap-x-4 print:gap-y-0.5">
      <IconLink
        icon={emailIcon}
        href={`mailto:${cv.head.email}`}
        alt={copy.iconAlt.email}
      />
      <!--<IconLink href={`tel:${cv.head}`} icon={phoneIcon}>-->
      <IconLink
        icon={linkedinIcon}
        href={cv.head.linkedin}
        alt={copy.iconAlt.linkedin}
      />
      <IconLink icon={linkIcon} href={cv.head.url} alt={copy.iconAlt.website} />
      <IconLink
        icon={githubIcon}
        href={cv.head.github}
        alt={copy.iconAlt.github}
      />
    </p>
  </section>

  <section>
    <h3>{copy.summary}</h3>
    <Fragment set:html={md2html(cv.summaryMD)} />
  </section>

  <section>
    <h3>{copy.experience}</h3>

    {
      cv.experience.map(exp => (
        <Org org={exp.org}>
          <div class={orgHeaderClass}>
            {exp.title ? <h4 class={orgTitleClass}>{exp.title}</h4> : null}
            <p class={exp.title ? orgMetaClass : orgTitleClass}>
              <a
                href={exp.org.url}
                target="_blank"
                rel="noreferrer"
                class={orgMetaLinkClass}
              >
                {exp.org.name}
              </a>
            </p>
            <p class={orgMutedClass}>{fmtExpTime({ ...exp, locale })}</p>
            <p class={orgMutedClass}>{exp.location}</p>
          </div>

          <Fragment set:html={md2html(exp.summaryMD)} />
          <Products products={exp.products} intro={copy.workedOn} />
        </Org>
      ))
    }
  </section>

  <section>
    <h3>{copy.education}</h3>

    {
      cv.education.map(ed => (
        <Org org={ed.org}>
          <div class={orgHeaderClass}>
            <h4 class={orgTitleClass}>
              <a
                href={ed.org.url}
                target="_blank"
                rel="noreferrer"
                class={orgLinkClass}
              >
                {ed.org.name}
              </a>
            </h4>
            <p class={orgMutedClass}>
              {fmtExpTime({ ...ed, duration: false, locale })}
            </p>
          </div>

          <Fragment set:html={md2html(ed.degreeMD)} />
          <Products products={ed.products} intro={copy.workedOn} />
        </Org>
      ))
    }
  </section>

  <section>
    <h3>{copy.awards}</h3>

    {
      cv.awards.map(aw => (
        <Org org={aw.org}>
          <div class={orgHeaderClass}>
            <h4 class={orgTitleClass}>
              <a
                href={aw.url}
                target="_blank"
                rel="noreferrer"
                class={orgLinkClass}
              >
                {aw.title}
              </a>
            </h4>
            <p class={orgMetaClass}>
              <a
                href={aw.org.url}
                target="_blank"
                rel="noreferrer"
                class={orgMetaLinkClass}
              >
                {aw.org.name}
              </a>
            </p>
            <p class={orgMutedClass}>{fmtDate(aw.date, locale)}</p>
          </div>
        </Org>
      ))
    }
  </section>
</SiteShell>
