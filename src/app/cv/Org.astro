---
import type { Org } from "./data/cv.types"
import images from "./ogimages.json"

interface Props {
  org: Org
}
const { org } = Astro.props
---

<div
  class="grid break-inside-avoid-page grid-cols-[3rem_minmax(0,1fr)] gap-x-4 py-3 first:pt-0 print:grid-cols-[1.75rem_minmax(0,1fr)] print:gap-x-2 print:py-1.5"
>
  <a
    class="not-prose block shrink-0"
    target="_blank"
    rel="noreferrer"
    href={org.url}
  >
    <img
      loading="eager"
      width={48}
      height={48}
      class="size-12 rounded-xl object-cover print:size-7 print:rounded-sm"
      src={org.imgURL ?? images[org.url as keyof typeof images]}
      alt={org.name}
    />
  </a>

  <div class="min-w-0">
    <slot />
  </div>
</div>
