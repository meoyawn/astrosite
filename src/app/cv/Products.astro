---
import { md2html } from "../markdown"

type Products = ReadonlyArray<{ name: string; url: string }>

interface Props {
  intro: string
  products: Products
}

const { intro, products } = Astro.props

const toMD = (items: Products, label: string): string =>
  `${label} ${items.map(x => `[${x.name}](${x.url})`).join(", ")}`
---

<Fragment set:html={md2html(toMD(products, intro))} />
