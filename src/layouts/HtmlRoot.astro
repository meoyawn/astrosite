---
import "../styles/global.css"
import faviconUrl from "../assets/favicon.svg?url&no-inline"

interface Props {
  title: string
  description?: string | undefined
  class?: string | undefined
  lang?: string | undefined
}

const { title, description, lang = "en" } = Astro.props
---

<!doctype html>
<html lang={lang} class="scroll-smooth motion-reduce:scroll-auto">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" sizes="any" href={faviconUrl} />
    <title>{title}</title>
    <meta name="description" content={description ?? "Personal website"} />
    <meta property="og:site_name" content="adelnz.com" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description ?? "Personal website"} />
  </head>

  <body class:list={["bg-white text-zinc-950", Astro.props.class]}>
    <slot />
  </body>
</html>
