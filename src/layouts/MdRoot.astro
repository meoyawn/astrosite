---
import SiteShell from "./SiteShell.astro"

interface Props {
  frontmatter: Partial<Record<"description" | "lang" | "title", string>>
}

const {
  frontmatter: { title, description, lang },
} = Astro.props
---

<SiteShell
  title={title!}
  description={description}
  lang={lang}
>
  <slot />
</SiteShell>
