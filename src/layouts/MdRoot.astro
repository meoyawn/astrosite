---
import SiteShell from "./SiteShell.astro"

interface Props {
  frontmatter: Partial<Record<"description" | "lang" | "title", string>>
}

const {
  frontmatter: { title, description, lang },
} = Astro.props
---

<SiteShell
  title={title!}
  description={description}
  lang={lang}
  class="prose mx-auto max-w-prose px-6 pb-6 sm:px-8 sm:pb-12 md:pb-16"
>
  <slot />
</SiteShell>
