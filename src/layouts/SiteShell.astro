---
import SiteNav from "../app/SiteNav.astro"
import { defaultLocale, locales, type Locale } from "../app/i18n"
import HtmlRoot from "./HtmlRoot.astro"

type SiteNavPath = "home" | "consulting" | "cv"

interface Props {
  class?: string | undefined
  currentPath?: SiteNavPath | undefined
  description?: string | undefined
  lang?: string | undefined
  navClass?: string | undefined
  title: string
}

const {
  title,
  description,
  lang = defaultLocale,
  currentPath: explicitCurrentPath,
  navClass,
  class: explicitContentClass,
} = Astro.props

const defaultContentWidthClass = "max-w-3xl"
const defaultContentClass = [
  "mx-auto prose px-6 pb-6 sm:px-8 sm:pb-12 md:pb-16",
  defaultContentWidthClass,
]
const currentLocale: Locale =
  locales.find(locale => locale === lang) ?? defaultLocale
const pathWithoutLocalePrefix = Astro.url.pathname.replace(
  /^\/(en|ru|tt)(?=\/|$)/,
  "",
)
const normalizedPath = pathWithoutLocalePrefix.replace(/\/$/, "") || "/"
const inferredCurrentPath: SiteNavPath | undefined =
  normalizedPath === "/"
    ? "home"
    : normalizedPath === "/consulting"
      ? "consulting"
      : normalizedPath === "/cv"
        ? "cv"
        : undefined
const currentPath = explicitCurrentPath ?? inferredCurrentPath
const contentClass = explicitContentClass ?? defaultContentClass
---

<HtmlRoot
  title={title}
  description={description}
  lang={currentLocale}
>
  <header
    class:list={[
      "mx-auto mt-6 px-6 sm:mt-12 sm:px-8 md:mt-16",
      currentPath === "cv" ? "max-w-prose" : defaultContentWidthClass,
      navClass,
    ]}
  >
    <SiteNav currentLocale={currentLocale} currentPath={currentPath} />
  </header>
  <main class:list={contentClass}>
    <slot />
  </main>
</HtmlRoot>
