---
import { getCollection, render } from "astro:content"
import GithubSlugger from "github-slugger"
import { defaultLocale } from "../../app/i18n"
import MdRoot from "../../layouts/MdRoot.astro"

// noinspection JSUnusedGlobalSymbols
export async function getStaticPaths() {
  const writingEntries = await getCollection("writing")
  writingEntries.sort(
    (a, b) =>
      (b.data.published_at?.getTime() ?? 0) - (a.data.published_at?.getTime() ?? 0),
  )
  return writingEntries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }))
}

const { entry } = Astro.props
const { Content } = await render(entry)
const publishedAt = entry.data.published_at
const updatedAt = entry.data.updated_at
const titleSlugger = new GithubSlugger()
const dateFormatter = new Intl.DateTimeFormat(defaultLocale, {
  day: "numeric",
  month: "short",
  timeZone: "UTC",
  year: "numeric",
})
const formatDate = (date: Date): string => dateFormatter.format(date)
const dateTime = (date: Date): string => date.toISOString().slice(0, 10)
const titleId = titleSlugger.slug(entry.data.title)
const shouldShowUpdatedAt = Boolean(
  publishedAt && updatedAt && dateTime(updatedAt) !== dateTime(publishedAt),
)
---

<MdRoot
  frontmatter={{
    title: entry.data.title,
    description: entry.data.description,
  }}
>
  <h1 id={titleId} class="mb-0">{entry.data.title}</h1>
  <p class="not-prose mt-2 mb-8 text-sm leading-6 font-medium text-zinc-500">
    {
      publishedAt ? (
        <>
          Published <time datetime={dateTime(publishedAt)}>{formatDate(publishedAt)}</time>
          {shouldShowUpdatedAt && updatedAt ? (
            <>
              {". "}
              Updated <time datetime={dateTime(updatedAt)}>{formatDate(updatedAt)}</time>
            </>
          ) : null}
        </>
      ) : (
        "Draft"
      )
    }
  </p>
  <Content />
</MdRoot>
