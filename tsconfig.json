{
  "extends": "astro/tsconfigs/strictest",
  "compilerOptions": {
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "noEmit": true,
    "plugins": [
      {
        "name": "@astrojs/ts-plugin",
      },
    ],
    "resolveJsonModule": true,
    "strictNullChecks": true,
    "types": ["bun"],
    "verbatimModuleSyntax": true,
  },
  "include": [".astro/types.d.ts", "*.ts", "src", "e2e", "scripts"],
}
